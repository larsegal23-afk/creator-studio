{
  "extends": ["web-recommended"],
  "hints": {
    "compat-api/css": [
      "warning",
      {
        "ignore": ["user-select"]
      }
    ],
    "no-inline-styles": "warning",
    "https-only": "error",
    "strict-transport-security": "error",
    "content-security-policy": "warning",
    "x-content-type-options": "error",
    "x-frame-options": "error",
    "no-vulnerable-javascript-libraries": "error"
  }
}