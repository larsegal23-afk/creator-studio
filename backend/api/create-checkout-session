app.post("/api/create-checkout-session", async (req, res) => {
  try {
    const { priceId } = req.body

    // 🔐 BASIC VALIDATION
    if (!priceId) {
      return res.status(400).json({ error: "Missing priceId" })
    }

    // 🔐 USER AUTH (Firebase Token erwartet)
    const authHeader = req.headers.authorization
    if (!authHeader || !authHeader.startsWith("Bearer ")) {
      return res.status(401).json({ error: "Unauthorized" })
    }

    const idToken = authHeader.split("Bearer ")[1]
    const decodedToken = await admin.auth().verifyIdToken(idToken)
    const uid = decodedToken.uid

    // 🔥 STRIPE SESSION
    const session = await stripe.checkout.sessions.create({
      mode: "payment",

      payment_method_types: ["card"],

      line_items: [
        {
          price: priceId,
          quantity: 1
        }
      ],

      success_url: "https://www.creator-studio-production-d0ed.up.railway.app/success.html",
      cancel_url: "https://www.creator-studio-production-d0ed.up.railway.app/cancel.html",

      // 🔥 WICHTIG → USER VERKNÜPFUNG
      metadata: {
        uid: uid
      }
    })

    res.json({ url: session.url })

  } catch (error) {
    console.error("Checkout Error:", error)
    res.status(500).json({ error: "Failed to create checkout session" })
  }
})