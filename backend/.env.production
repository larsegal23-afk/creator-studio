# Firebase Configuration - REPLACE WITH YOUR ACTUAL VALUES
FIREBASE_PROJECT_ID=logomakergermany-kreativtool
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@logomakergermany-kreativtool.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_ACTUAL_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# OpenAI Configuration - REPLACE WITH YOUR ACTUAL KEY
OPENAI_API_KEY=sk-your-actual-openai-key

# Stripe Configuration - REPLACE WITH LIVE KEYS FOR PRODUCTION
STRIPE_SECRET_KEY=sk_live_your_actual_live_key
STRIPE_WEBHOOK_SECRET=whsec_your_actual_webhook_secret

# Application Configuration
NODE_ENV=production
PORT=3000
FRONTEND_BASE_URL=https://logomakergermany-kreativtool.web.app

# Security
UPLOAD_TOKEN_SECRET=your-secure-upload-token-secret-12345

# Backend URL
BACKEND_URL=https://logomakergermany-ultimate-backend-production.up.railway.app
